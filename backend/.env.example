NODE_ENV=development
PORT=3001

# Veritabanı (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=crm_db
DB_USER=crm_user
DB_PASSWORD=change_me

# Redis (gelecekte cache/queue için)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT — prod'da rastgele üretilmiş 32+ karakterli değer kullanın
JWT_SECRET=replace_with_long_random_secret_min_32_chars
JWT_REFRESH_SECRET=replace_with_long_random_refresh_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Frontend (virgülle birden fazla origin desteklenir)
FRONTEND_URL=http://localhost:5173

# (Opsiyonel) SMTP — e-posta bildirimi için
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="CRM <no-reply@example.com>"
